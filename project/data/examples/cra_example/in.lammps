log log.${fn}.${nfi}.lammps
#
# Choose metalic units and that point particles are to be simulated
# 
units metal
atom_style atomic
#
# Choose full 3D pbc
#
boundary  p p p
#
# Allow for internal atom data to be accessible in this script
#
atom_modify map array
#
# If the file number is zero, construct a perfect bcc lattice, otherwise,
# read in an existing configuration (currently 10*10*10)
# 
if "${fn}==0" then &
    "lattice bcc 3.1651956" &
    "region box block 0 5 0 5 0 5" &
    "create_box 1 box" &
    "create_atoms 1 box" &
else &
    "read_data relax.${fn}.lammps"
#
# Set mass of W atom
#
mass 1  183.84
#
# Define EAM potential to be used
#
pair_style eam/fs
pair_coeff  * * W_mason17.eam.fs W
#
# Choose when and how often neighbour lists are updated
#
neighbor   0.3  bin
neigh_modify  every  1  delay  0  check  yes
#
# Choose global variables to be outputed every 100 iterations
#
thermo  100
thermo_style  custom  step  pe  vol  press pxx pyy pzz pxy pxz pyz xlo xhi ylo yhi zlo zhi
#
# During cg minimization allow the box-length along the x-direction to vary to achieve sigma_xx=0 (omit for isotropic fixed strain case)
#
fix 1 all box/relax x 0.0 vmax 0.001
#
# If zero relax (only necessary for the presence of a surface) and ouput the initial lattice
#
if "${fn}==0" then &
    "minimize 1.0e-15 1.0e-15 10000 10000" &
    "write_data relax.0.lammps"
#
# Ouput random seed produce by the system
#
print "Seed: ${seed}"
#
# Create a random variable to select a particle
#
variable rid equal round(random(0.5,atoms+0.5,${seed}))
#
# Perform "nfi" Frenkel insertions
#
variable sfn equal ${fn}+1
variable ffn equal ${fn}+${nfi}
variable i loop ${sfn} ${ffn}
label loop
#
# Randomly select the particle
#
variable atomid equal ${rid}
#
# Choose a new location for it within the simulation cell
#
variable newx equal random(xlo,xhi,${seed})
variable newy equal random(ylo,yhi,${seed})
variable newz equal random(zlo,zhi,${seed})
#
# Caclulate the displacement of the particle
#
variable delx equal ${newx}-x[${atomid}]
variable dely equal ${newy}-y[${atomid}]
variable delz equal ${newz}-z[${atomid}]
#
# Displace the particle
#
print 'dispalced atom ( ${atomid} , ${delx}, ${dely}, ${delz} )'
group sub id ${atomid}
displace_atoms sub move v_delx v_dely v_delz units box
group sub clear 
#
# Perform the cg relaxation
#
minimize 1.0e-10 1.0e-10 10000 10000
#
# Ouput the configuration every 2nd (say) fenkel insertion
#
variable a equal ${i}%1 #for every 2nd change %1 to %2
if "$a==0" then "write_data relax.$i.lammps"

next i
jump in.lammps loop








